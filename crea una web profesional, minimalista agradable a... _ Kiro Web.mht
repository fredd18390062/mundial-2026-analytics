                'Inglaterra vs Arabia Saudita - Over 10.5'
            ],
            odds: 5.10,
            reason: 'España promedia 11 corners totales, Alemania 11.6, Inglaterra 11.0. Equipos dominantes generan muchos corners.'
        }
    ];
    
    container.innerHTML = parlays.map(parlay =&gt; `
        &lt;div class="pick-card"&gt;
            &lt;div class="pick-header"&gt;
                &lt;div class="pick-title"&gt;${parlay.title}&lt;/div&gt;
                &lt;div class="pick-odds"&gt;@${parlay.odds}&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="pick-details"&gt;
                ${parlay.picks.map(pick =&gt; `&lt;div&gt;✓ ${pick}&lt;/div&gt;`).join('')}
            &lt;/div&gt;
            &lt;div class="pick-reason"&gt;
                📊 Análisis: ${parlay.reason}
            &lt;/div&gt;
        &lt;/div&gt;
    `).join('');
}

// Render straight bets
function renderStraightBets() {
    const container = document.getElementById('straight-list');
    
    const straightBets = [
        {
            title: 'Brasil gana vs Túnez',
