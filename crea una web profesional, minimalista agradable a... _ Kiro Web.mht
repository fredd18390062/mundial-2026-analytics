// Bet tracking
function handleBetSubmit(e) {
    e.preventDefault();
    
    const bet = {
        id: Date.now(),
        match: document.getElementById('bet-match').value,
        type: document.getElementById('bet-type').value,
        pick: document.getElementById('bet-pick').value,
        stake: parseFloat(document.getElementById('bet-stake').value),
        odds: parseFloat(document.getElementById('bet-odds').value),
        status: 'pending',
        date: new Date().toISOString()
    };
    
    AppState.bets.push(bet);
    saveBetsToStorage();
    updateBetsDisplay();
    
    // Reset form
    e.target.reset();
    
    // Show success message
    alert('✅ Apuesta registrada correctamente');
}

function updateBetsDisplay() {
    updateBetsSummary();
    renderBetsTable();
}

function updateBetsSummary() {
    const wins = AppState.bets.filter(b =&gt; b.status === 'won').length;
    const losses = AppState.bets.filter(b =&gt; b.status === 'lost').length;
    const pending = AppState.bets.filter(b =&gt; b.status === 'pending').length;
    
    document.getElementById('wins-count').textContent = wins;
    document.getElementById('losses-count').textContent = losses;
    document.getElementById('pending-count').textContent = pending;
    
    // Calculate ROI
    const totalStake = AppState.bets.reduce((sum, b) =&gt; sum + b.stake, 0);
    const totalReturn = AppState.bets
        .filter(b =&gt; b.status === 'won')
        .reduce((sum, b) =&gt; sum + (b.stake * b.odds), 0);
    const roi = totalStake &gt; 0 ? (((totalReturn - totalStake) / totalStake) * 100).toFixed(1) : 0;
    
    document.getElementById('roi').textContent = `${roi}%`;
    document.getElementById('roi').className = roi &gt; 0 ? 'green' : roi &lt; 0 ? 'red' : '';
}

function renderBetsTable() {
    const container = document.getElementById('bets-table');
    
    if (AppState.bets.length === 0) {
        container.innerHTML = '&lt;div class="empty-state"&gt;&lt;p&gt;No hay apuestas registradas&lt;/p&gt;&lt;/div&gt;';
        return;
    }
    
    container.innerHTML = AppState.bets.slice().reverse().map(bet =&gt; `
        &lt;div class="bet-item ${bet.status}"&gt;
            &lt;div class="bet-header"&gt;
                &lt;div class="bet-match"&gt;${bet.match}&lt;/div&gt;
                &lt;div class="bet-type"&gt;${bet.type.toUpperCase()}&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class="bet-details"&gt;
                &lt;div class="bet-detail"&gt;&lt;strong&gt;Pick:&lt;/strong&gt; ${bet.pick}&lt;/div&gt;
                &lt;div class="bet-detail"&gt;&lt;strong&gt;Monto:&lt;/strong&gt; $${bet.stake.toFixed(2)}&lt;/div&gt;
                &lt;div class="bet-detail"&gt;&lt;strong&gt;Momio:&lt;/strong&gt; @${bet.odds}&lt;/div&gt;
                &lt;div class="bet-detail"&gt;&lt;strong&gt;Ret. Potencial:&lt;/strong&gt; $${(bet.stake * bet.odds).toFixed(2)}&lt;/div&gt;
                &lt;div class="bet-detail"&gt;&lt;strong&gt;Estado:&lt;/strong&gt; ${getStatusText(bet.status)}&lt;/div&gt;
            &lt;/div&gt;
            ${bet.status === 'pending' ? `
            &lt;div class="bet-actions"&gt;
                &lt;button class="btn-small btn-won" onclick="updateBetStatus(${bet.id}, 'won')"&gt;✓ Ganada&lt;/button&gt;
                &lt;button class="btn-small btn-lost" onclick="updateBetStatus(${bet.id}, 'lost')"&gt;✗ Perdida&lt;/button&gt;
                &lt;button class="btn-small btn-delete" onclick="deleteBet(${bet.id})"&gt;🗑️ Eliminar&lt;/button&gt;
            &lt;/div&gt;
            ` : ''}
        &lt;/div&gt;
    `).join('');
}

function getStatusText(status) {
    const statusMap = {
        'pending': '⏳ Pendiente',
        'won': '✅ Ganada',
        'lost': '❌ Perdida'
    };
    return statusMap[status] || status;
}

function updateBetStatus(betId, newStatus) {
    const bet = AppState.bets.find(b =&gt; b.id === betId);
    if (bet) {
        bet.status = newStatus;
        saveBetsToStorage();
        updateBetsDisplay();
    }
}

function deleteBet(betId) {
    if (confirm('¿Estás seguro de eliminar esta apuesta?')) {
        AppState.bets = AppState.bets.filter(b =&gt; b.id !== betId);
        saveBetsToStorage();
        updateBetsDisplay();
    }
}

function saveBetsToStorage() {
    localStorage.setItem('worldcup2026_bets', JSON.stringify(AppState.bets));
}

function loadBetsFromStorage() {
    const stored = localStorage.getItem('worldcup2026_bets');
    if (stored) {
        AppState.bets = JSON.parse(stored);
    }
}
