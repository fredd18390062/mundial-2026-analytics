&lt;!DOCTYPE html&gt;
&lt;html lang="es"&gt;
&lt;head&gt;
    &lt;meta charset="UTF-8"&gt;
    &lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
    &lt;title&gt;Mundial 2026 - Análisis Profesional&lt;/title&gt;
    &lt;link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"&gt;
    &lt;style&gt;
/* Reset and Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary-color: #1a1a2e;
    --secondary-color: #16213e;
    --accent-color: #0f3460;
    --green: #10b981;
    --yellow: #fbbf24;
    --red: #ef4444;
    --text-primary: #ffffff;
    --text-secondary: #9ca3af;
    --border-color: #374151;
    --card-bg: #1f2937;
    --hover-bg: #2d3748;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: var(--text-primary);
    min-height: 100vh;
    line-height: 1.6;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Header */
.header {
    background: rgba(31, 41, 55, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--accent-color);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    flex-wrap: wrap;
    gap: 1rem;
}

.logo {
    font-size: 1.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, #10b981, #3b82f6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.nav-btn {
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--text-secondary);
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 0.95rem;
}

.nav-btn:hover {
    background: var(--hover-bg);
    color: var(--text-primary);
}

.nav-btn.active {
    background: var(--accent-color);
    color: var(--text-primary);
    border-color: #3b82f6;
}

/* Main Content */
.main-content {
    padding: 2rem 0 4rem;
    min-height: calc(100vh - 200px);
}

/* Legend Card */
.legend-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
}

.legend-card h3 {
    margin-bottom: 1rem;
    font-size: 1.2rem;
}

.legend-items {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.color-box {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    border: 2px solid rgba(255, 255, 255, 0.2);
}

.color-box.green {
    background: var(--green);
}

.color-box.yellow {
    background: var(--yellow);
}

.color-box.red {
    background: var(--red);
}

.data-info {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
}

/* Views */
.view {
    display: none;
}

.view.active {
    display: block;
}

/* Filter Section */
.filter-section {
    margin-bottom: 2rem;
}

.filter-section h2 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
}

.group-filters,
.confederation-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.group-btn,
.conf-btn {
    padding: 0.75rem 1.5rem;
    background: var(--card-bg);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 0.95rem;
}

.group-btn:hover,
.conf-btn:hover {
    background: var(--hover-bg);
    border-color: #3b82f6;
}

.group-btn.active,
.conf-btn.active {
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    border-color: #3b82f6;
}

/* Team Cards */
.team-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.team-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 12px rgba(0, 0, 0, 0.3);
}

.team-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-color);
}

.team-name {
    font-size: 1.8rem;
    font-weight: 700;
}

.team-flag {
    font-size: 2.5rem;
}

.team-group-info {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.stat-item {
    background: var(--secondary-color);
    padding: 1rem;
    border-radius: 8px;
    border-left: 4px solid var(--border-color);
}

.stat-item.highlight-green {
    border-left-color: var(--green);
    background: rgba(16, 185, 129, 0.1);
}

.stat-item.highlight-yellow {
    border-left-color: var(--yellow);
    background: rgba(251, 191, 36, 0.1);
}

.stat-item.highlight-red {
    border-left-color: var(--red);
    background: rgba(239, 68, 68, 0.1);
}

.stat-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
    font-weight: 500;
}

.stat-value {
    font-size: 1.5rem;
    font-weight: 700;
}

.stat-value.green {
    color: var(--green);
}

.stat-value.yellow {
    color: var(--yellow);
}

.stat-value.red {
    color: var(--red);
}

/* Probabilities */
.probabilities {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}

.prob-item {
    flex: 1;
    min-width: 120px;
    text-align: center;
    padding: 1rem;
    background: var(--secondary-color);
    border-radius: 8px;
}

.prob-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.prob-value {
    font-size: 1.8rem;
    font-weight: 700;
}

/* Form Section */
.form-section {
    background: var(--secondary-color);
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1rem;
}

.form-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.form-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
}

/* Hot Data */
.hot-data {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.2), rgba(249, 115, 22, 0.2));
    padding: 1rem;
    border-radius: 8px;
    border: 2px solid #f97316;
    margin-top: 1rem;
}

.hot-data-title {
    font-size: 0.85rem;
    color: #fbbf24;
    font-weight: 600;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.hot-data-text {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
}

/* Source Note */
.source-note {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 1rem;
    font-style: italic;
}

/* Stats Summary */
.stats-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}

.stat-card {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
    border: 2px solid var(--border-color);
}

.stat-card.green {
    border-color: var(--green);
    background: rgba(16, 185, 129, 0.1);
}

.stat-card.yellow {
    border-color: var(--yellow);
    background: rgba(251, 191, 36, 0.1);
}

.stat-card.red {
    border-color: var(--red);
    background: rgba(239, 68, 68, 0.1);
}

.stat-card h3 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
}

.stat-card p {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

/* Form Styles */
.add-bet-section {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border: 1px solid var(--border-color);
}

.add-bet-section h3 {
    margin-bottom: 1rem;
}

#bet-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
}

input,
select {
    padding: 0.75rem;
    background: var(--secondary-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    font-family: inherit;
}

input:focus,
select:focus {
    outline: none;
    border-color: #3b82f6;
}

.btn-primary {
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    color: var(--text-primary);
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
}

/* Bets Table */
.bets-list {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
}

.bet-item {
    background: var(--secondary-color);
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    border-left: 4px solid var(--border-color);
}

.bet-item.won {
    border-left-color: var(--green);
    background: rgba(16, 185, 129, 0.1);
}

.bet-item.lost {
    border-left-color: var(--red);
    background: rgba(239, 68, 68, 0.1);
}

.bet-item.pending {
    border-left-color: var(--yellow);
}

.bet-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
}

.bet-match {
    font-weight: 700;
    font-size: 1.1rem;
}

.bet-type {
    padding: 0.25rem 0.75rem;
    background: var(--accent-color);
    border-radius: 4px;
    font-size: 0.85rem;
}

.bet-details {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
}

.bet-detail {
    font-size: 0.9rem;
}

.bet-detail strong {
    color: var(--text-secondary);
}

.bet-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
}

.btn-small {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    transition: transform 0.2s ease;
}

.btn-small:hover {
    transform: translateY(-1px);
}

.btn-won {
    background: var(--green);
    color: white;
}

.btn-lost {
    background: var(--red);
    color: white;
}

.btn-delete {
    background: var(--border-color);
    color: var(--text-primary);
}

/* Picks Section */
.picks-sections {
    margin-top: 2rem;
}

.parlays-section,
.straight-section {
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    border: 1px solid var(--border-color);
}

.pick-card {
    background: var(--secondary-color);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    border-left: 4px solid #3b82f6;
}

.pick-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.pick-title {
    font-size: 1.2rem;
    font-weight: 700;
}

.pick-odds {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--green);
}

.pick-details {
    margin-bottom: 0.5rem;
}

.pick-reason {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-color);
}

/* Footer */
.footer {
    background: var(--card-bg);
    padding: 2rem 0;
    text-align: center;
    border-top: 2px solid var(--border-color);
    margin-top: 3rem;
}

.footer p {
    color: var(--text-secondary);
    margin: 0.5rem 0;
}

/* Responsive */
@media (max-width: 768px) {
    .header-content {
        flex-direction: column;
        align-items: flex-start;
    }

    .logo {
        font-size: 1.5rem;
    }

    .nav {
        width: 100%;
    }

    .nav-btn {
        flex: 1;
        min-width: calc(50% - 0.25rem);
    }

    .team-name {
        font-size: 1.5rem;
    }

    .stats-grid {
        grid-template-columns: 1fr;
    }

    .probabilities {
        flex-direction: column;
    }

    .form-row {
        grid-template-columns: 1fr;
    }
}

/* Loading State */
.loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-secondary);
}

.loading::after {
    content: '⚽';
    animation: spin 1s linear infinite;
    display: inline-block;
    font-size: 2rem;
    margin-left: 1rem;
}

@keyframes spin {
    100% {
        transform: rotate(360deg);
    }
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text-secondary);
}

.empty-state h3 {
    margin-bottom: 1rem;
    color: var(--text-primary);
}
    &lt;/style&gt;
