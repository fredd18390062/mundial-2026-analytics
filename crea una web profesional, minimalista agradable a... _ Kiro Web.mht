        },
        {
            title: 'Parlay Over Goles',
            picks: [
                'Argentina vs Haití - Over 2.5',
                'Brasil vs Túnez - Over 2.5',
                'España vs Japón - Over 2.5'
            ],
            odds: 4.20,
            reason: 'Los tres equipos tienen Over 2.5 en más del 68% de sus partidos. Argentina promedia 2.55 goles por partido.'
        },
        {
            title: 'Parlay Corners',
            picks: [
                'España vs Japón - Over 10.5 corners',
