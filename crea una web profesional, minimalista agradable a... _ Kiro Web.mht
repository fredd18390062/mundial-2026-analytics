}

function renderForm(form) {
    if (!form || form.length === 0) return 'Sin datos';
    
    return form.map(result =&gt; {
        const color = result === 'G' ? 'green' : result === 'E' ? 'yellow' : 'red';
        return `&lt;span class="stat-value ${color}" style="font-size: 1rem; margin-right: 0.25rem;"&gt;${result}&lt;/span&gt;`;
    }).join('');
}

// Render top picks
function renderTopPicks() {
    const container = document.getElementById('picks-container');
    
    // Ordenar equipos por probabilidad de victoria
    const teamsWithStats = [];
    for (const [teamName, stats] of Object.entries(TEAM_STATS)) {
        if (stats.probabilities.win !== null) {
            teamsWithStats.push({ name: teamName, stats });
        }
    }
    
    teamsWithStats.sort((a, b) =&gt; b.stats.probabilities.win - a.stats.probabilities.win);
    
    container.innerHTML = '&lt;div class="stats-grid"&gt;';
    
    teamsWithStats.slice(0, 8).forEach((item, index) =&gt; {
        const flag = FLAGS[item.name] || '🏴';
        container.innerHTML += `
            &lt;div class="stat-item highlight-green"&gt;
                &lt;div class="stat-label"&gt;#${index + 1} ${flag} ${item.name}&lt;/div&gt;
                &lt;div class="stat-value green"&gt;${item.stats.probabilities.win}% victoria&lt;/div&gt;
                &lt;p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;"&gt;
                    ${item.stats.hotData}
                &lt;/p&gt;
            &lt;/div&gt;
        `;
    });
    
    container.innerHTML += '&lt;/div&gt;';
}

