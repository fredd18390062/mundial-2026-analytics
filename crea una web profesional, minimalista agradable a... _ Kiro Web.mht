 Main Application
// Desarrollado para análisis profesional de datos de fútbol

// Estado de la aplicación
const AppState = {
    currentView: 'grupos',
    selectedGroup: 'A',
    selectedConfederation: 'UEFA',
    bets: []
};

// Inicialización
document.addEventListener('DOMContentLoaded', () =&gt; {
    initializeApp();
    loadBetsFromStorage();
    updateBetsDisplay();
});

function initializeApp() {
    // Navigation
    document.querySelectorAll('.nav-btn').forEach(btn =&gt; {
        btn.addEventListener('click', (e) =&gt; {
            switchView(e.target.dataset.view);
        });
    });

    // Group filters
    document.querySelectorAll('.group-btn').forEach(btn =&gt; {
        btn.addEventListener('click', (e) =&gt; {
            selectGroup(e.target.dataset.group);
        });
    });

    // Confederation filters
    document.querySelectorAll('.conf-btn').forEach(btn =&gt; {
        btn.addEventListener('click', (e) =&gt; {
            selectConfederation(e.target.dataset.conf);
        });
    });

    // Bet form
    document.getElementById('bet-form')?.addEventListener('submit', handleBetSubmit);

    // Load initial view
    renderGroupTeams('A');
    renderTopPicks();
}

// View switching
function switchView(viewName) {
    AppState.currentView = viewName;
    
    // Update nav buttons
    document.querySelectorAll('.nav-btn').forEach(btn =&gt; {
        btn.classList.toggle('active', btn.dataset.view === viewName);
    });

    // Update views
    document.querySelectorAll('.view').forEach(view =&gt; {
        view.classList.remove('active');
    });
    document.getElementById(`view-${viewName}`).classList.add('active');

    // Load view-specific data
    if (viewName === 'grupos') {
        renderGroupTeams(AppState.selectedGroup);
    } else if (viewName === 'confederaciones') {
        renderConfederationTeams(AppState.selectedConfederation);
    } else if (viewName === 'picks') {
        renderTopPicks();
        renderParlays();
        renderStraightBets();
    }
}

// Group selection
function selectGroup(groupId) {
    AppState.selectedGroup = groupId;
    
    document.querySelectorAll('.group-btn').forEach(btn =&gt; {
        btn.classList.toggle('active', btn.dataset.group === groupId);
    });
    
    renderGroupTeams(groupId);
}

// Confederation selection
function selectConfederation(conf) {
    AppState.selectedConfederation = conf;
    
    document.querySelectorAll('.conf-btn').forEach(btn =&gt; {
        btn.classList.toggle('active', btn.dataset.conf === conf);
    });
    
    renderConfederationTeams(conf);
}

// Render teams by group
function renderGroupTeams(groupId) {
    const container = document.getElementById('teams-container');
    const groupData = WORLD_CUP_DATA.groups[groupId];
    
    if (!groupData) {
        container.innerHTML = '&lt;div class="empty-state"&gt;&lt;h3&gt;Grupo no encontrado&lt;/h3&gt;&lt;/div&gt;';
        return;
    }

    container.innerHTML = `&lt;h2 style="margin-bottom: 1.5rem;"&gt;📋 ${groupData.name}&lt;/h2&gt;`;
    
    groupData.teams.forEach(teamName =&gt; {
        const stats = getTeamStats(teamName);
        container.innerHTML += renderTeamCard(teamName, stats);
    });
}

// Render teams by confederation
function renderConfederationTeams(conf) {
    const container = document.getElementById('confederation-container');
    const teams = WORLD_CUP_DATA.confederations[conf];
    
    if (!teams) {
        container.innerHTML = '&lt;div class="empty-state"&gt;&lt;h3&gt;Confederación no encontrada&lt;/h3&gt;&lt;/div&gt;';
        return;
    }

    container.innerHTML = `&lt;h2 style="margin-bottom: 1.5rem;"&gt;🌍 ${conf} - ${teams.length} equipos&lt;/h2&gt;`;
    
    teams.forEach(teamName =&gt; {
        const stats = getTeamStats(teamName);
        container.innerHTML += renderTeamCard(teamName, stats);
    });
}

// Render team card
function renderTeamCard(teamName, stats) {
    const flag = FLAGS[teamName] || '🏴';
    
    // Determinar clase de probabilidad
    const probClass = stats.probabilities.win &gt;= 60 ? 'green' : 
                      stats.probabilities.win &gt;= 40 ? 'yellow' : 'red';
    
    // Determinar clase de goles
    const goalsClass = stats.goalsFor &gt;= 2.0 ? 'highlight-green' : 
                       stats.goalsFor &gt;= 1.5 ? 'highlight-yellow' : 'highlight-red';
    
    // Determinar clase BTTS
    const bttsClass = stats.btts &gt;= 50 ? 'highlight-green' : 
                      stats.btts &gt;= 35 ? 'highlight-yellow' : 'highlight-red';
    
    const hasData = stats.probabilities.win !== null;
    
    return `
        &lt;div class="team-card"&gt;
            &lt;div class="team-header"&gt;
                &lt;div&gt;
                    &lt;h2 class="team-name"&gt;${flag} ${teamName}&lt;/h2&gt;
                    &lt;p class="team-group-info"&gt;Grupo ${stats.group} | ${stats.confederation}&lt;/p&gt;
                &lt;/div&gt;
                &lt;div class="team-flag"&gt;${flag}&lt;/div&gt;
            &lt;/div&gt;

            ${hasData ? `
            &lt;!-- Probabilidades --&gt;
            &lt;div class="probabilities"&gt;
                &lt;div class="prob-item"&gt;
                    &lt;div class="prob-label"&gt;Victoria&lt;/div&gt;
                    &lt;div class="prob-value green"&gt;${stats.probabilities.win}%&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="prob-item"&gt;
                    &lt;div class="prob-label"&gt;Empate&lt;/div&gt;
                    &lt;div class="prob-value yellow"&gt;${stats.probabilities.draw}%&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="prob-item"&gt;
                    &lt;div class="prob-label"&gt;Derrota&lt;/div&gt;
                    &lt;div class="prob-value red"&gt;${stats.probabilities.loss}%&lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;

            &lt;!-- Estadísticas principales --&gt;
            &lt;div class="stats-grid"&gt;
                &lt;div class="stat-item ${goalsClass}"&gt;
                    &lt;div class="stat-label"&gt;⚽ Goles a Favor (promedio)&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.goalsFor.toFixed(2)}&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item ${stats.goalsAgainst &lt;= 0.8 ? 'highlight-green' : 'highlight-yellow'}"&gt;
                    &lt;div class="stat-label"&gt;🛡️ Goles en Contra (promedio)&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.goalsAgainst.toFixed(2)}&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item ${stats.overUnder.over25 &gt;= 60 ? 'highlight-green' : 'highlight-yellow'}"&gt;
                    &lt;div class="stat-label"&gt;📊 Over 2.5 Goles&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.overUnder.over25}%&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item ${bttsClass}"&gt;
                    &lt;div class="stat-label"&gt;🎯 Ambos Marcan (BTTS)&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.btts}%&lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;

            &lt;!-- Corners y Tarjetas --&gt;
            &lt;div class="stats-grid"&gt;
                &lt;div class="stat-item"&gt;
                    &lt;div class="stat-label"&gt;🚩 Corners a Favor&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.corners.for.toFixed(1)}&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item"&gt;
                    &lt;div class="stat-label"&gt;🚩 Corners en Contra&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.corners.against.toFixed(1)}&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item ${stats.corners.for + stats.corners.against &gt;= 10 ? 'highlight-green' : 'highlight-yellow'}"&gt;
                    &lt;div class="stat-label"&gt;📌 Línea Sugerida Corners&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.corners.suggested}&lt;/div&gt;
                &lt;/div&gt;
                &lt;div class="stat-item ${stats.cards.average &gt;= 4 ? 'highlight-green' : 'highlight-yellow'}"&gt;
                    &lt;div class="stat-label"&gt;🟨 Tarjetas Promedio&lt;/div&gt;
                    &lt;div class="stat-value"&gt;${stats.cards.average.toFixed(1)} | ${stats.cards.suggested}&lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;

            &lt;!-- Posesión y Forma --&gt;
            &lt;div class="form-section"&gt;
                &lt;div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;"&gt;
                    &lt;div&gt;
                        &lt;div class="form-label"&gt;📊 Posesión Promedio&lt;/div&gt;
                        &lt;div class="form-value"&gt;${stats.possession}%&lt;/div&gt;
                    &lt;/div&gt;
                    &lt;div&gt;
                        &lt;div class="form-label"&gt;🎯 Remates al Arco&lt;/div&gt;
                        &lt;div class="form-value"&gt;${stats.shotsOnTarget.toFixed(1)}&lt;/div&gt;
                    &lt;/div&gt;
                    &lt;div&gt;
                        &lt;div class="form-label"&gt;📈 Últimos 5 Partidos&lt;/div&gt;
                        &lt;div class="form-value"&gt;${renderForm(stats.form)}&lt;/div&gt;
                    &lt;/div&gt;
                &lt;/div&gt;
            &lt;/div&gt;

            &lt;!-- Dato Caliente --&gt;
            &lt;div class="hot-data"&gt;
                &lt;div class="hot-data-title"&gt;🔥 DATO CALIENTE&lt;/div&gt;
                &lt;div class="hot-data-text"&gt;${stats.hotData}&lt;/div&gt;
            &lt;/div&gt;

            &lt;p class="source-note"&gt;
                📅 Actualizado: ${stats.lastUpdated} | 
                📊 Fuente: ${stats.source} | 
                ⚠️ Promedios basados en últimos 20 partidos oficiales
            &lt;/p&gt;
            ` : `
            &lt;div class="empty-state"&gt;
                &lt;h3&gt;⚠️ Datos Insuficientes&lt;/h3&gt;
                &lt;p&gt;Este equipo requiere actualización de estadísticas.&lt;/p&gt;
                &lt;p&gt;Por favor consulte directamente: FBref, SofaScore, WhoScored&lt;/p&gt;
            &lt;/div&gt;
            `}
        &lt;/div&gt;
    `;
}

function renderForm(form) {
    if (!form || form.length === 0) return 'Sin datos';
    
    return form.map(result =&gt; {
        const color = result === 'G' ? 'green' : result === 'E' ? 'yellow' : 'red';
        return `&lt;span class="stat-value ${color}" style="font-size: 1rem; margin-right: 0.25rem;"&gt;${result}&lt;/span&gt;`;
    }).join('');
}

// Render top picks
function renderTopPicks() {
    const container = document.getElementById('picks-container');
    
    // Ordenar equipos por probabilidad de victoria
    const teamsWithStats = [];
    for (const [teamName, stats] of Object.entries(TEAM_STATS)) {
        if (stats.probabilities.win !== null) {
            teamsWithStats.push({ name: teamName, stats });
        }
    }
    
    teamsWithStats.sort((a, b) =&gt; b.stats.probabilities.win - a.stats.probabilities.win);
    
    container.innerHTML = '&lt;div class="stats-grid"&gt;';
    
    teamsWithStats.slice(0, 8).forEach((item, index) =&gt; {
        const flag = FLAGS[item.name] || '🏴';
        container.innerHTML += `
            &lt;div class="stat-item highlight-green"&gt;
                &lt;div class="stat-label"&gt;#${index + 1} ${flag} ${item.name}&lt;/div&gt;
                &lt;div class="stat-value green"&gt;${item.stats.probabilities.win}% victoria&lt;/div&gt;
                &lt;p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.5rem;"&gt;
                    ${item.stats.hotData}
                &lt;/p&gt;
            &lt;/div&gt;
        `;
    });
    
    container.innerHTML += '&lt;/div&gt;';
}

// Render parlays
function renderParlays() {
    const container = document.getElementById('parlays-list');
    
    const parlays = [
        {
            title: 'Parlay de Favoritos',
            picks: [
                'Brasil gana vs Túnez',
                'España gana vs Curaçao',
